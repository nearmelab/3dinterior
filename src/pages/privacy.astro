---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/home/Navbar.astro';
import Footer from '../components/shared/Footer.astro';
import PrivacySidebar from '../components/privacy/PrivacySidebar.astro';
import PrivacyContent from '../components/privacy/PrivacyContent.astro';
import ScrollToTop from '../components/privacy/ScrollToTop.astro';
---

<Layout title="Privacy Policy | Legal Center">
  <Navbar />
  
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex flex-col lg:flex-row gap-12">
      <PrivacySidebar />
      <PrivacyContent />
    </div>
  </main>
  
  <ScrollToTop />
  <Footer />
</Layout>