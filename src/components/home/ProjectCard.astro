---
import Icon from '../shared/Icon.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

export interface Props {
  title: string;
  category: string;
  year: string;
  image: ImageMetadata;  // Changed from string to ImageMetadata
  alt: string;
  index: number;
}

const { title, category, year, image, alt, index } = Astro.props;
const isEven = index % 2 === 0;
---

<div class="group cursor-pointer" class:list={[!isEven && 'md:mt-24']}>
  <div class="relative aspect-[4/3] overflow-hidden rounded bg-slate-100 dark:bg-slate-800">
    <div class="absolute inset-0 bg-primary/0 group-hover:bg-primary/10 transition-colors duration-500 z-10" />
    <Image
  src={image}
  alt={alt}
  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
  loading="lazy"
  decoding="async"
  layout="constrained"
  width={800}
  height={600}
  format="webp"
  fit="cover"
  widths={[320, 640, 768, 1024]}
  sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
  quality={75}
/>
  </div>
  <div class="mt-6 flex justify-between items-start">
    <div>
      <h3 class="text-xl font-bold uppercase tracking-tight group-hover:text-primary transition-colors">{title}</h3>
      <p class="text-slate-500 dark:text-slate-400 text-sm font-medium uppercase tracking-widest mt-1">{category} / {year}</p>
    </div>
    <Icon name="arrow-right" size={20} class="text-primary opacity-0 group-hover:opacity-100 transition-opacity" />
  </div>
</div>