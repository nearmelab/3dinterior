---
export interface Props {
  id: string;
  title: string;
  content: string;
  subsections?: Array<{ title: string; content: string }>;
  list?: string[];
}

const { id, title, content, subsections, list } = Astro.props;
---

<section id={id} class="scroll-mt-28">
  <h2 class="text-slate-900 dark:text-slate-100 text-2xl font-bold mt-12 mb-4">
    {title}
  </h2>
  
  <p class="text-slate-600 dark:text-slate-400 text-base leading-relaxed mb-4">
    {content}
  </p>
  
  {subsections?.map((subsection) => (
    <>
      <h3 class="text-slate-900 dark:text-slate-100 text-lg font-semibold mt-8 mb-3">
        {subsection.title}
      </h3>
      <p class="text-slate-600 dark:text-slate-400 text-base leading-relaxed mb-4">
        {subsection.content}
      </p>
    </>
  ))}
  
  {list && (
    <ul class="list-disc pl-6 mb-4 text-slate-600 dark:text-slate-400 space-y-2">
      {list.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  )}
</section>