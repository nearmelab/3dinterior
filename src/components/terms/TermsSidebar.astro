---
import Icon from '../shared/Icon.astro';

const sections = [
  { id: 'acceptance', title: '1. Acceptance of Terms', icon: 'file-check' },
  { id: 'accounts', title: '2. User Accounts', icon: 'users' },
  { id: 'conduct', title: '3. User Conduct', icon: 'shield' },
  { id: 'intellectual', title: '4. Intellectual Property', icon: 'copyright' },
  { id: 'liability', title: '5. Limitation of Liability', icon: 'scale' },
  { id: 'termination', title: '6. Termination', icon: 'circle-x' }
];
---

<aside class="hidden lg:block w-64 flex-shrink-0">
  <div class="sticky top-28 space-y-1">
    <p class="text-xs font-bold uppercase tracking-widest text-slate-400 mb-4 px-3">
      On this page
    </p>
    
    {sections.map((section, index) => (
      <a
        href={`#${section.id}`}
        class:list={[
          "flex items-center gap-3 px-3 py-2 text-sm font-medium rounded-lg transition-colors",
          index === 0 
            ? "text-primary bg-primary/10 border-l-2 border-primary" 
            : "text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800"
        ]}
      >
        <Icon name={section.icon} size={18} />
        {section.title}
      </a>
    ))}
    
    <div class="mt-10 pt-6 border-t border-slate-200 dark:border-slate-800">
      <button class="flex items-center gap-2 text-sm font-semibold text-primary hover:underline w-full">
        <Icon name="download" size={20} />
        Download as PDF
      </button>
    </div>
  </div>
</aside>