---
import Icon from '../shared/Icon.astro';
---

<div class="mt-16 p-8 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl">
  <h2 class="text-slate-900 dark:text-slate-100 text-2xl font-bold !mt-0">Contact Us</h2>
  <p class="text-slate-600 dark:text-slate-400 text-base leading-relaxed mb-6">
    If you have any questions about these Terms, please contact our legal department:
  </p>
  
  <div class="space-y-4">
    <div class="flex items-start gap-4">
      <Icon name="mail" size={24} class="text-primary flex-shrink-0" />
      <div>
        <p class="font-bold mb-0">Email</p>
        <p class="text-sm text-slate-600 dark:text-slate-400">legal@example.com</p>
      </div>
    </div>
    
    <div class="flex items-start gap-4">
      <Icon name="map-pin" size={24} class="text-primary flex-shrink-0" />
      <div>
        <p class="font-bold mb-0">Office</p>
        <p class="text-sm text-slate-600 dark:text-slate-400">
          123 Legal Plaza, Suite 400<br/>San Francisco, CA 94105
        </p>
      </div>
    </div>
    
    <div class="flex items-start gap-4">
      <Icon name="phone" size={24} class="text-primary flex-shrink-0" />
      <div>
        <p class="font-bold mb-0">Phone</p>
        <p class="text-sm text-slate-600 dark:text-slate-400">+1 (555) 123-4567</p>
      </div>
    </div>
  </div>
</div>