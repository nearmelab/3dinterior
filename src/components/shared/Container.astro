---
export interface Props {
  class?: string;
  as?: keyof HTMLElementTagNameMap;
  size?: 'sm' | 'md' | 'lg' | 'xl' | 'full';
}

const { class: className = '', as: Tag = 'div', size = 'xl' } = Astro.props;

const maxWidths = {
  sm: 'max-w-3xl',
  md: 'max-w-5xl',
  lg: 'max-w-6xl',
  xl: 'max-w-7xl',
  full: 'max-w-full'
};
---

<Tag class:list={[maxWidths[size], 'mx-auto px-6', className]}>
  <slot />
</Tag>