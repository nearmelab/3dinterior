---
export interface Props {
  label: string;
  placeholder?: string;
  name: string;
  rows?: number;
  required?: boolean;
}

const { label, placeholder = '', name, rows = 6, required = false } = Astro.props;
---

<div class="space-y-2">
  <label for={name} class="text-xs font-bold uppercase tracking-widest text-slate-400">{label}</label>
  <textarea
    id={name}
    name={name}
    placeholder={placeholder}
    rows={rows}
    required={required}
    class="w-full bg-slate-50 dark:bg-slate-800 border-slate-200 dark:border-slate-700 rounded p-4 focus:ring-1 focus:ring-primary focus:border-primary transition-all outline-none resize-none"
  />
</div>