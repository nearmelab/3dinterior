---
import { Image } from 'astro:assets';

export interface Props {
  src: string | ImageMetadata;
  alt: string;
  class?: string;
  width?: number;
  height?: number;
  layout?: 'constrained' | 'fixed' | 'full-width';
  loading?: 'eager' | 'lazy';
  decoding?: 'async' | 'sync' | 'auto';
  fetchpriority?: 'high' | 'low' | 'auto';
  format?: 'avif' | 'webp' | 'png' | 'jpg';
  fit?: 'cover' | 'contain' | 'fill' | 'inside' | 'outside';
  position?: 'center' | 'top' | 'right' | 'bottom' | 'left' | string;
}

const {
  src,
  alt,
  class: className = '',
  width,
  height,
  layout = 'constrained',
  loading = 'lazy',
  decoding = 'async',
  fetchpriority = 'auto',
  format = 'webp',
  fit = 'cover',
  position = 'center',
} = Astro.props;

// Check if src is a remote URL (string) or local import (ImageMetadata)
const isRemoteUrl = typeof src === 'string' && (src.startsWith('http') || src.startsWith('/'));
---

{
  isRemoteUrl ? (
    // For remote URLs, use with appropriate attributes
    <img 
      src={src} 
      alt={alt} 
      class={className}
      width={width}
      height={height}
      loading={loading}
      decoding={decoding}
      fetchpriority={fetchpriority}
      style={{
        objectFit: fit,
        objectPosition: position,
      }}
    />
  ) : (
    // For local images, use Astro's Image component
    <Image
      src={src}
      alt={alt}
      class={className}
      width={width}
      height={height}
      layout={layout}
      loading={loading}
      decoding={decoding}
      fetchpriority={fetchpriority}
      format={format}
      fit={fit}
      position={position}
    />
  )
}