---
export interface Props {
  href: string;
  active?: boolean;
  class?: string;
}

const { href, active = false, class: className = '' } = Astro.props;
---

<a 
  href={href}
  class:list={[
    "text-sm font-semibold transition-colors",
    active 
      ? "text-primary" 
      : "text-slate-600 dark:text-slate-400 hover:text-primary dark:hover:text-primary",
    className
  ]}
>
  <slot />
</a>