---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

export interface Props {
  title: string;
  location: string;
  year: string;
  category: string;
  image: ImageMetadata | string;  // Accept both types
  alt: string;
}

const { title, location, year, category, image, alt } = Astro.props;
---

<div class="group cursor-pointer">
  <div class="relative overflow-hidden aspect-[4/3] mb-4 bg-slate-200 dark:bg-slate-800 rounded">
    {typeof image === 'string' ? (
      // If it's a string URL, use img tag
      <img
        src={image}
        alt={alt}
        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
        loading="lazy"
        decoding="async"
      />
    ) : (
      // If it's ImageMetadata, use Astro Image
<Image
  src={image}
  alt={alt}
  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
  loading="lazy"
  decoding="async"
  layout="constrained"
  width={800}
  height={600}
  format="webp"
  fit="cover"
  widths={[320, 480, 640, 800]}
  sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
  quality={70}
/>
    )}
  </div>
  <div class="flex justify-between items-start">
    <div>
      <h3 class="text-slate-900 dark:text-slate-100 text-lg font-semibold tracking-tight">{title}</h3>
      <p class="text-slate-500 dark:text-slate-400 text-sm font-light">{category} • {location}</p>
    </div>
    <span class="text-slate-400 text-sm font-medium">{year}</span>
  </div>
</div>