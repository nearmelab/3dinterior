---
import Container from '../shared/Container.astro';

const filters = [
  { name: "All Projects", active: true },
  { name: "Residential", active: false },
  { name: "Commercial", active: false },
  { name: "Urban Design", active: false },
  { name: "Cultural", active: false },
  { name: "Interior", active: false }
];
---

<Container>
  <div class="flex flex-wrap gap-2 mb-10 border-b border-slate-200 dark:border-slate-800 pb-6">
    {filters.map((filter) => (
      <button
        class:list={[
          "px-5 py-2 rounded text-sm font-medium transition-all",
          filter.active
            ? "bg-primary text-white"
            : "text-slate-600 dark:text-slate-400 hover:bg-slate-200 dark:hover:bg-slate-800"
        ]}
      >
        {filter.name}
      </button>
    ))}
  </div>
</Container>