---
import Container from '../shared/Container.astro';
import ProjectCard from './ProjectCard.astro';
import project1Image from '../../assets/img/projects-page-img-01.jpg';
import project2Image from '../../assets/img/projects-page-img-02.jpg';
import project3Image from '../../assets/img/projects-page-img-03.jpg';
import project4Image from '../../assets/img/projects-page-img-04.jpg';
import project5Image from '../../assets/img/projects-page-img-05.jpg';
import project6Image from '../../assets/img/projects-page-img-06.jpg';

const projects = [
  {
    title: "Skyline Residence",
    category: "Residential",
    location: "Zurich, Switzerland",
    year: "2023",
    image: project1Image,  // This is the imported ImageMetadata object
    alt: "Modern minimalist luxury villa with large glass windows"
  },
  {
    title: "Metropolitan Plaza",
    category: "Commercial",
    location: "New York, USA",
    year: "2022",
    image: project2Image,
    alt: "High-rise glass office building in metropolitan area"
  },
  {
    title: "The Glass Pavilion",
    category: "Cultural",
    location: "Oslo, Norway",
    year: "2023",
    image: project3Image,
    alt: "Abstract geometrical white architectural facade with shadows"
  },
  {
    title: "Riverside Lofts",
    category: "Residential",
    location: "London, UK",
    year: "2021",
    image: project4Image,
    alt: "Industrial chic loft apartment interior with brick walls"
  },
  {
    title: "Nordic Cultural Center",
    category: "Cultural",
    location: "Stockholm, Sweden",
    year: "2022",
    image: project5Image,
    alt: "Modern concrete library building with sharp angles"
  },
  {
    title: "Desert Oasis Villa",
    category: "Residential",
    location: "Dubai, UAE",
    year: "2023",
    image: project6Image,
    alt: "Modern villa with swimming pool at sunset"
  }
];
---

<Container>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    {projects.map((project) => (
      <ProjectCard
        title={project.title}
        category={project.category}
        location={project.location}
        year={project.year}
        image={project.image}  // Passing the ImageMetadata object
        alt={project.alt}
      />
    ))}
  </div>
</Container>