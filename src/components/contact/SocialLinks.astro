---
import Icon from '../shared/Icon.astro';
---

<div class="pt-6 border-t border-slate-200 dark:border-slate-800">
  <h3 class="text-xs font-bold uppercase tracking-[0.2em] text-slate-400 mb-6">Social Registry</h3>
  <div class="flex gap-8">
    <a href="#" class="text-slate-600 dark:text-slate-400 hover:text-primary transition-colors text-sm font-bold tracking-tighter uppercase flex items-center gap-2">
      <Icon name="brand-instagram" size={18} />
      Instagram
    </a>
    <a href="#" class="text-slate-600 dark:text-slate-400 hover:text-primary transition-colors text-sm font-bold tracking-tighter uppercase flex items-center gap-2">
      <Icon name="brand-linkedin" size={18} />
      LinkedIn
    </a>
    <a href="#" class="text-slate-600 dark:text-slate-400 hover:text-primary transition-colors text-sm font-bold tracking-tighter uppercase flex items-center gap-2">
      <Icon name="brand-behance" size={18} />
      ArchDaily
    </a>
  </div>
</div>