---
import { Image } from 'astro:assets';
import mapImage from '../../assets/img/contact-page-img-01.png';
---

<div class="relative group overflow-hidden rounded border border-slate-200 dark:border-slate-800 h-80 lg:h-96">
  <div class="absolute inset-0 bg-slate-200 dark:bg-slate-800">
    <Image
  src={mapImage}
  alt="Minimalist grayscale map of New York City showing studio location"
  class="w-full h-full object-cover grayscale opacity-50 contrast-125"
  loading="lazy"
  decoding="async"
  layout="full-width"
  format="webp"
  fit="cover"
  widths={[640, 1024, 1280]}
  sizes="(max-width: 1024px) 100vw, 50vw"
  quality={70}
/>
    <div class="absolute inset-0 bg-primary/10 group-hover:bg-transparent transition-all duration-500" />
  </div>
</div>