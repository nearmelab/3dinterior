---
import Input from '../shared/Input.astro';
import Textarea from '../shared/Textarea.astro';
import Select from '../shared/Select.astro';
import Icon from '../shared/Icon.astro';

const projectTypes = [
  { value: 'residential', label: 'Residential' },
  { value: 'commercial', label: 'Commercial' },
  { value: 'interior', label: 'Interior Design' },
  { value: 'urban', label: 'Urban Planning' }
];
---

<div class="bg-white dark:bg-slate-900 p-8 md:p-12 rounded shadow-sm border border-slate-200 dark:border-slate-800">
  <form action="#" class="space-y-8" method="POST">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <Input label="Full Name" name="name" placeholder="Jane Doe" required />
      <Input label="Email Address" name="email" type="email" placeholder="jane@example.com" required />
    </div>
    
    <Select label="Project Type" name="projectType" options={projectTypes} />
    
    <Textarea 
      label="Message" 
      name="message" 
      placeholder="Tell us about your project goals, location, and timeline..." 
      rows={6} 
      required 
    />
    
    <button 
      type="submit" 
      class="w-full md:w-auto bg-primary text-white px-10 py-4 rounded font-bold uppercase tracking-widest hover:bg-primary/90 transition-all flex items-center justify-center gap-3 group"
    >
      Send Inquiry
      <Icon name="send" size={18} class="transition-transform group-hover:translate-x-1" />
    </button>
  </form>
</div>