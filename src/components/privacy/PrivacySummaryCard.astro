---
import Icon from '../shared/Icon.astro';
---

<div class="p-4 bg-primary/5 rounded-lg border border-primary/10">
  <div class="flex items-start gap-3">
    <Icon name="info-circle" size={20} class="text-primary flex-shrink-0 mt-0.5" />
    <div>
      <h4 class="text-sm font-bold text-slate-900 dark:text-white mb-2">Need a summary?</h4>
      <p class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed">
        We value your privacy. This policy explains how we collect and protect your personal information in accordance with GDPR and CCPA.
      </p>
    </div>
  </div>
</div>