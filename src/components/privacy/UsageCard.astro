---
import Icon from '../shared/Icon.astro';

export interface Props {
  icon: string;
  title: string;
  description: string;
}

const { icon, title, description } = Astro.props;
---

<li class="flex gap-4 p-4 rounded-xl bg-slate-50 dark:bg-slate-800/50 hover:bg-primary/5 transition-colors">
  <Icon name={icon} size={24} class="text-primary flex-shrink-0" />
  <div>
    <span class="block font-bold mb-1">{title}</span>
    <p class="text-sm text-slate-600 dark:text-slate-400">{description}</p>
  </div>
</li>