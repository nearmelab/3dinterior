---
import Icon from '../shared/Icon.astro';
---

<div class="mb-10 pb-10 border-b border-slate-200 dark:border-slate-800">
  <div class="inline-flex items-center px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-bold mb-4 gap-1">
    <Icon name="shield" size={14} />
    <span>Legal Document</span>
  </div>
  <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-slate-900 dark:text-white mb-4">
    Privacy Policy
  </h1>
  <p class="text-slate-500 dark:text-slate-400 flex items-center gap-4">
    <span class="flex items-center gap-1">
      <Icon name="calendar" size={16} class="text-slate-400" />
      Last Updated: <time datetime="2023-10-24">October 24, 2023</time>
    </span>
    <span class="text-slate-300">•</span>
    <span class="flex items-center gap-1">
      <Icon name="file-text" size={16} class="text-slate-400" />
      Version 2.4
    </span>
  </p>
</div>