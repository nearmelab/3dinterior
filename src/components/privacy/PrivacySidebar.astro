---
import PrivacySummaryCard from './PrivacySummaryCard.astro';
import Icon from '../shared/Icon.astro';

const sections = [
  { id: 'introduction', title: 'Introduction', icon: 'info-circle' },
  { id: 'data-collection', title: 'Data Collection', icon: 'database' },
  { id: 'how-we-use', title: 'How We Use Data', icon: 'settings' },
  { id: 'third-parties', title: 'Third-Party Sharing', icon: 'share' },
  { id: 'your-rights', title: 'Your Rights', icon: 'badge' },
  { id: 'cookies', title: 'Cookie Policy', icon: 'cookie' },
  { id: 'contact', title: 'Contact Us', icon: 'mail' }
];
---

<aside class="lg:w-1/4">
  <div class="sticky top-28 space-y-6">
    <div>
      <h3 class="text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500 mb-4 flex items-center gap-2">
        <Icon name="list" size={16} />
        Table of Contents
      </h3>
      <nav class="space-y-1">
        {sections.map((section, index) => (
          <a
            href={`#${section.id}`}
            class:list={[
              "flex items-center gap-3 px-3 py-2 text-sm font-medium rounded transition-colors",
              index === 0
                ? "bg-primary/10 text-primary"
                : "text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800"
            ]}
          >
            <Icon name={section.icon} size={18} />
            {section.title}
          </a>
        ))}
      </nav>
    </div>
    
    <PrivacySummaryCard />
  </div>
</aside>