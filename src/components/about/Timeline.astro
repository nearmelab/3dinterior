---
import Icon from '../shared/Icon.astro';

export interface Props {
  year: string;
  title: string;
  description: string;
  isFirst?: boolean;
}

const { year, title, description, isFirst = false } = Astro.props;
---

<div class="relative pl-8 border-l border-slate-200 dark:border-slate-800">
  <div class:list={[
    "absolute -left-[5px] top-0 size-2.5 rounded-full",
    isFirst ? "bg-primary" : "bg-primary/40"
  ]} />
  <span class="text-xs font-black text-primary">{year}</span>
  <p class="font-bold mt-1">{title}</p>
  <p class="text-sm text-slate-500 mt-2 italic">{description}</p>
</div>